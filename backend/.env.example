# Copy this file to .env in the same folder (backend/) and fill in real values.
# Never commit .env.

# Postgres (same driver as in requirements: psycopg v3)
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/postgres

# JWT signing key — use a long random string in production (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string
